# ---- Gemini (AI Studio) — needed for --correct and the field agent ----
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ---- Google Cloud Speech-to-Text (Chirp) — only for the google_cloud engine ----
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ---- OpenAI Whisper API — only for the whisper_api engine ----
# OPENAI_API_KEY=your-openai-api-key

# ---- Agent model (optional; defaults to gemini-flash-latest) ----
# S2T_AGENT_MODEL=gemini-flash-latest
